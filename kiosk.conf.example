# =============================================================================
#  kiosk.conf — local configuration overrides
# =============================================================================
#
#  Copy this file to kiosk.conf and set your values.
#  This file is sourced by kiosk-setup.sh after the built-in defaults,
#  so anything you set here overrides the script without editing it.
#
#  This file is listed in .gitignore — git pull will never touch it.
#
#  Usage:
#    cp kiosk.conf.example kiosk.conf
#    nano kiosk.conf
#    sudo bash kiosk-setup.sh [URL]
#
#  Only set the variables you want to override — everything else falls
#  back to the defaults in kiosk-setup.sh.
# =============================================================================

# Dashboard URL to display (can also be passed as the first argument)
# KIOSK_URL="http://192.168.1.149:8123/dashboard-wall/home"

# ── Home Assistant auto-login ─────────────────────────────────────────────────
# HA_AUTO_LOGIN=true
# HA_URL="http://192.168.1.149:8123"
# HA_TOKEN="your-long-lived-token-here"   # must be on ONE line — no line breaks
# HA_DASHBOARD_PATH="/dashboard-wall/home"

# ── browser_mod ───────────────────────────────────────────────────────────────
# ENABLE_BROWSER_MOD=true
# BROWSER_MOD_ID="kiosk-front-door"

# ── Display API (hardware brightness control) ─────────────────────────────────
# ENABLE_DISPLAY_API=true
# DISPLAY_API_PORT=2701
# Bind address: 0.0.0.0 = all interfaces (default), 127.0.0.1 = localhost only.
# Use 0.0.0.0 when HA runs on a separate machine (most setups).
# DISPLAY_API_BIND=0.0.0.0

# Set false for displays that don't support software screen on/off or brightness
# (e.g. portable HDMI displays, some USB-C monitors). The API still runs for
# health/status endpoints, but /screen/on, /screen/off, and /brightness become
# no-ops. Leave true for wall panels with sysfs backlight or DDC/CI support.
# ENABLE_SCREEN_CONTROL=true

# ── Waveshare 10.1DP-CAPLCD display ──────────────────────────────────────────
# WAVESHARE_10DP=true

# Pull-to-refresh gesture (default: true — enabled)
# Set to false to disable the pull-down-to-refresh touch gesture.
# Recommended: false for wall-mounted kiosks to prevent accidental reloads.
# ENABLE_PULL_TO_REFRESH=false

# ── Touch-to-wake ──────────────────────────────────────────────────────────────
# Wake the screen when someone taps while the backlight is off.
# Uses kernel-level evdev input grab — Chromium receives ZERO touch events
# while the screen is dark, so no accidental dashboard triggers.
# Requires: ENABLE_DISPLAY_API=true  and  python3-evdev installed.
# ENABLE_TOUCH_TO_WAKE=true

# Brightness to restore when the screen wakes from a touch:
#   last  — restore the brightness level set before screen-off (recommended)
#   1-100 — always wake to this specific brightness
# TOUCH_WAKE_BRIGHTNESS=last

# Extra milliseconds to absorb touch events after waking (default: 300).
# The wake tap itself is always swallowed. This covers slow lift-offs or
# multi-finger gestures. Set to 0 to disable the extra swallow window.
# TOUCH_WAKE_SWALLOW_MS=300

# ── Scheduled shutdown/wake (requires RTC hardware) ──────────────────────────
# SHUTDOWN_HOUR=23
# SHUTDOWN_MINUTE=0
# WAKE_HOUR=7
# WAKE_MINUTE=0

# ── On-screen keyboard ────────────────────────────────────────────────────────
# ENABLE_OSK=false

# ── Display rotation (Trixie/Wayland only) ────────────────────────────────────
# DISPLAY_TRANSFORM="normal"    # normal | 90 | 180 | 270
# DISPLAY_OUTPUT="HDMI-A-1"     # run wlr-randr to find your output name

# ── Auto-reload page every N seconds (0 = disabled) ──────────────────────────
# AUTO_RELOAD_SECONDS=0

# ── Remove desktop bloat during install ──────────────────────────────────────
# REMOVE_BLOAT=true
